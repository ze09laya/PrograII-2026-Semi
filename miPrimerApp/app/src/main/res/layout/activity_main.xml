<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1B1B1B">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:paddingBottom="90dp">


        <EditText
            android:id="@+id/txtcodigoAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Código"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtdescripcionAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtcodigoAmigos"
            android:layout_marginTop="10dp"
            android:hint="Descripción"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtmarcaAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtdescripcionAmigos"
            android:layout_marginTop="10dp"
            android:hint="Marca"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtpresentacionAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtmarcaAmigos"
            android:layout_marginTop="10dp"
            android:hint="Presentación"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtprecioAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtpresentacionAmigos"
            android:layout_marginTop="10dp"
            android:hint="Precio"
            android:inputType="numberDecimal"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtcostoAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtprecioAmigos"
            android:layout_marginTop="10dp"
            android:hint="Costo"
            android:inputType="numberDecimal"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <EditText
            android:id="@+id/txtstockAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtcostoAmigos"
            android:layout_marginTop="10dp"
            android:hint="Stock"
            android:inputType="number"
            android:textColor="#E0E0E0"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#2E2E2E" />


        <ImageButton
            android:id="@+id/imgFotoAmigo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_below="@id/txtstockAmigos"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:background="#2E2E2E"
            android:src="@drawable/camara"
            android:scaleType="centerCrop"
            android:contentDescription="foto"
            app:tint="#E0E0E0" />


        <Button
            android:id="@+id/btnGuardarAmigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/imgFotoAmigo"
            android:layout_marginTop="20dp"
            android:text="Guardar Producto"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E2E2E" />


        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabListaAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="20dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFFFFF"
            app:backgroundTint="#2E2E2E" />

    </RelativeLayout>

</ScrollView>