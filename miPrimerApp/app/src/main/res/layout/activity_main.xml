<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/black">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:paddingBottom="90dp">

        <!-- CODIGO -->
        <EditText
            android:id="@+id/txtcodigoAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Código"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- DESCRIPCION -->
        <EditText
            android:id="@+id/txtdescripcionAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtcodigoAmigos"
            android:layout_marginTop="10dp"
            android:hint="Descripción"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- MARCA -->
        <EditText
            android:id="@+id/txtmarcaAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtdescripcionAmigos"
            android:layout_marginTop="10dp"
            android:hint="Marca"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- PRESENTACION -->
        <EditText
            android:id="@+id/txtpresentacionAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtmarcaAmigos"
            android:layout_marginTop="10dp"
            android:hint="Presentación"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- PRECIO -->
        <EditText
            android:id="@+id/txtprecioAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtpresentacionAmigos"
            android:layout_marginTop="10dp"
            android:hint="Precio"
            android:inputType="numberDecimal"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- COSTO -->
        <EditText
            android:id="@+id/txtcostoAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtprecioAmigos"
            android:layout_marginTop="10dp"
            android:hint="Costo"
            android:inputType="numberDecimal"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- STOCK -->
        <EditText
            android:id="@+id/txtstockAmigos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txtcostoAmigos"
            android:layout_marginTop="10dp"
            android:hint="Stock"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="@color/grayText"
            android:backgroundTint="@color/accent" />

        <!-- FOTO -->
        <ImageButton
            android:id="@+id/imgFotoAmigo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_below="@id/txtstockAmigos"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:background="@color/darkGray"
            android:src="@drawable/camara"
            android:scaleType="centerCrop"
            android:contentDescription="foto" />

        <!-- GUARDAR -->
        <Button
            android:id="@+id/btnGuardarAmigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/imgFotoAmigo"
            android:layout_marginTop="20dp"
            android:text="Guardar Producto"
            android:textColor="@color/black"
            android:backgroundTint="@color/accent" />

        <!-- BOTÓN REGRESAR -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabListaAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="20dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/black"
            app:backgroundTint="@color/accent" />

    </RelativeLayout>

</ScrollView>