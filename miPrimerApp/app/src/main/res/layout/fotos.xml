<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardImagen"
        android:layout_width="70dp"
        android:layout_height="70dp"
        app:cardCornerRadius="50dp"
        app:cardBackgroundColor="@color/darkGray">

        <ImageView
            android:id="@+id/imgFotoAdaptador"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/lblcodigoAdaptador"
        android:layout_toEndOf="@id/cardImagen"
        android:layout_marginStart="10dp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:text="Código"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/lbldescripcionAdaptador"
        android:layout_below="@id/lblcodigoAdaptador"
        android:layout_toEndOf="@id/cardImagen"
        android:layout_marginStart="10dp"
        android:textColor="@color/grayText"
        android:text="Descripción"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/lblmarcaAdaptador"
        android:layout_below="@id/lbldescripcionAdaptador"
        android:layout_toEndOf="@id/cardImagen"
        android:layout_marginStart="10dp"
        android:textColor="@color/grayText"
        android:text="Marca"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</RelativeLayout>